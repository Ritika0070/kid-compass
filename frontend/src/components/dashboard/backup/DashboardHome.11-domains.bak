import { useAuth } from "../../hooks/useAuth";

const domains = [
  { name: "Logical-Analytical", short: "Logic", color: "#2563eb" },
  { name: "Creative-Artistic", short: "Creative", color: "#9333ea" },
  { name: "Verbal-Linguistic", short: "Verbal", color: "#dc2626" },
  { name: "Spatial-Visual", short: "Spatial", color: "#0891b2" },
  { name: "Interpersonal-Social", short: "Social", color: "#16a34a" },
  { name: "Bodily-Kinesthetic", short: "Movement", color: "#d97706" },
];

const roadmap = [
  "Create child profile",
  "Start Adventure Hub",
  "Complete first game",
  "Review first insight",
];

function StatCard({ label, value, helper }) {
  return (
    <div className="rounded-2xl border border-[#e4e7df] bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <p className="text-sm font-semibold text-[#6b7280]">{label}</p>
      <p className="mt-3 text-3xl font-extrabold text-[#111827]">{value}</p>
      <p className="mt-2 text-sm text-[#6b7280]">{helper}</p>
    </div>
  );
}

function ProgressRing({ value = 0 }) {
  const radius = 48;
  const circumference = 2 * Math.PI * radius;
  const strokeDashoffset = circumference - (value / 100) * circumference;

  return (
    <div className="flex items-center gap-5">
      <div className="relative h-32 w-32 shrink-0">
        <svg viewBox="0 0 120 120" className="h-full w-full -rotate-90">
          <circle
            cx="60"
            cy="60"
            r={radius}
            fill="none"
            stroke="#e5e9df"
            strokeWidth="12"
          />
          <circle
            cx="60"
            cy="60"
            r={radius}
            fill="none"
            stroke="#1f7a4d"
            strokeWidth="12"
            strokeLinecap="round"
            strokeDasharray={circumference}
            strokeDashoffset={strokeDashoffset}
          />
        </svg>
        <div className="absolute inset-0 flex flex-col items-center justify-center">
          <span className="text-3xl font-extrabold text-[#111827]">{value}%</span>
          <span className="text-xs font-semibold text-[#6b7280]">complete</span>
        </div>
      </div>

      <div>
        <h3 className="text-lg font-extrabold text-[#111827]">Assessment Progress</h3>
        <p className="mt-2 text-sm leading-6 text-[#6b7280]">
          Progress will increase as games are completed. No scores are generated before a test is taken.
        </p>
      </div>
    </div>
  );
}

function EmptyBarChart() {
  return (
    <div className="h-72">
      <div className="flex h-full items-end gap-3 border-b border-l border-[#e4e7df] px-2 pb-4">
        {domains.map((domain) => (
          <div key={domain.name} className="flex h-full min-w-0 flex-1 flex-col justify-end">
            <div className="relative flex flex-1 items-end justify-center">
              <div className="h-full w-full max-w-[44px] rounded-t-2xl bg-[#eef1e8]" />
              <div
                className="absolute bottom-0 h-1 w-full max-w-[44px] rounded-t-2xl"
                style={{ backgroundColor: domain.color }}
              />
            </div>
            <p className="mt-3 truncate text-center text-xs font-bold text-[#6b7280]">
              {domain.short}
            </p>
          </div>
        ))}
      </div>
    </div>
  );
}

function EmptyRadarChart() {
  const center = 95;
  const levels = [72, 50, 28];

  return (
    <div className="flex items-center justify-center">
      <svg viewBox="0 0 190 190" className="h-64 w-full max-w-[300px]">
        {levels.map((size) => (
          <polygon
            key={size}
            points={domains
              .map((_, index) => {
                const angle = (Math.PI * 2 * index) / domains.length - Math.PI / 2;
                return `${center + Math.cos(angle) * size},${center + Math.sin(angle) * size}`;
              })
              .join(" ")}
            fill="none"
            stroke="#dde4d4"
            strokeWidth="1"
          />
        ))}

        {domains.map((domain, index) => {
          const angle = (Math.PI * 2 * index) / domains.length - Math.PI / 2;
          const x = center + Math.cos(angle) * 82;
          const y = center + Math.sin(angle) * 82;
          const labelX = center + Math.cos(angle) * 92;
          const labelY = center + Math.sin(angle) * 92;

          return (
            <g key={domain.name}>
              <line x1={center} y1={center} x2={x} y2={y} stroke="#e4e7df" />
              <circle cx={x} cy={y} r="4" fill={domain.color} />
              <text
                x={labelX}
                y={labelY}
                textAnchor="middle"
                dominantBaseline="middle"
                fontSize="8"
                fontWeight="700"
                fill="#6b7280"
              >
                {domain.short}
              </text>
            </g>
          );
        })}

        <polygon
          points="95,95 95,95 95,95 95,95 95,95 95,95"
          fill="#1f7a4d22"
          stroke="#1f7a4d"
          strokeWidth="2"
        />

        <text
          x="95"
          y="100"
          textAnchor="middle"
          fontSize="12"
          fontWeight="800"
          fill="#111827"
        >
          No data yet
        </text>
      </svg>
    </div>
  );
}

function TimelineChart() {
  return (
    <div className="space-y-4">
      {roadmap.map((item, index) => {
        const done = index === 0;

        return (
          <div key={item} className="flex gap-4">
            <div className="flex flex-col items-center">
              <div
                className={`flex h-9 w-9 items-center justify-center rounded-full text-sm font-extrabold ${
                  done ? "bg-[#1f7a4d] text-white" : "bg-[#eef1e8] text-[#6b7280]"
                }`}
              >
                {index + 1}
              </div>
              {index < roadmap.length - 1 && <div className="mt-2 h-8 w-px bg-[#e4e7df]" />}
            </div>

            <div className="pt-1">
              <p className="font-bold text-[#111827]">{item}</p>
              <p className="mt-1 text-sm text-[#6b7280]">
                {done ? "Completed" : "Pending"}
              </p>
            </div>
          </div>
        );
      })}
    </div>
  );
}

function ConfidenceChart() {
  const items = [
    { label: "Speech", value: 0 },
    { label: "Detail", value: 0 },
    { label: "Energy", value: 0 },
    { label: "Comfort", value: 0 },
  ];

  return (
    <div className="space-y-4">
      {items.map((item) => (
        <div key={item.label}>
          <div className="flex items-center justify-between">
            <p className="text-sm font-bold text-[#111827]">{item.label}</p>
            <p className="text-sm font-bold text-[#6b7280]">Pending</p>
          </div>
          <div className="mt-2 h-2 rounded-full bg-[#e5e9df]">
            <div
              className="h-2 rounded-full bg-[#1f7a4d]"
              style={{ width: `${item.value}%` }}
            />
          </div>
        </div>
      ))}
    </div>
  );
}

export default function DashboardHome() {
  const { user } = useAuth();
  const childName = user?.name || "Your child";

  const completedGames = 0;
  const gemsEarned = 0;
  const progressPercent = Math.round((completedGames / 6) * 100);

  return (
    <div className="mx-auto max-w-7xl space-y-6">
      <section className="grid gap-5 xl:grid-cols-[1.4fr_0.9fr]">
        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <div className="flex flex-col justify-between gap-5 md:flex-row md:items-start">
            <div>
              <p className="text-sm font-bold uppercase tracking-[0.14em] text-[#1f7a4d]">
                Child Profile
              </p>

              <h1
                className="mt-2 text-4xl font-extrabold text-[#111827]"
                style={{ fontFamily: "'Baloo 2', cursive" }}
              >
                {childName}'s Interest Snapshot
              </h1>

              <p className="mt-3 max-w-2xl text-base leading-7 text-[#5f6673]">
                A clean overview of assessment progress, domain readiness,
                confidence snapshot, and parent-facing insights.
              </p>
            </div>

            <div className="rounded-2xl bg-[#f6f7f4] px-5 py-4">
              <p className="text-sm font-semibold text-[#6b7280]">Assessment status</p>
              <p className="mt-1 text-xl font-extrabold text-[#111827]">Not started</p>
              <p className="mt-1 text-sm text-[#6b7280]">No game data yet</p>
            </div>
          </div>
        </div>

        <div className="rounded-3xl border border-[#dce8d3] bg-[#eef7e8] p-6 shadow-sm">
          <p className="text-sm font-bold uppercase tracking-[0.14em] text-[#1f7a4d]">
            Parent Insight
          </p>

          <p className="mt-4 text-lg font-semibold leading-7 text-[#223226]">
            No insight is available yet. Once {childName} completes activities,
            this area will summarize current interests without making predictions.
          </p>
        </div>
      </section>

      <section className="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        <StatCard label="Games Completed" value={`${completedGames}/6`} helper="Adventure progress" />
        <StatCard label="Gems Earned" value={gemsEarned} helper="Earned after games" />
        <StatCard label="Top Interest" value="Pending" helper="Available after assessments" />
        <StatCard label="Confidence" value="Pending" helper="After Talk with Buddy" />
      </section>

      <section className="grid gap-6 xl:grid-cols-[0.9fr_1.25fr_0.85fr]">
        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <ProgressRing value={progressPercent} />
        </div>

        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <div className="flex items-start justify-between gap-4">
            <div>
              <h2 className="text-xl font-extrabold text-[#111827]">Domain Score Chart</h2>
              <p className="mt-1 text-sm text-[#6b7280]">
                Bars activate after each game is completed.
              </p>
            </div>
            <span className="rounded-full bg-[#f6f7f4] px-3 py-1 text-xs font-bold text-[#6b7280]">
              0 records
            </span>
          </div>

          <div className="mt-6">
            <EmptyBarChart />
          </div>
        </div>

        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <h2 className="text-xl font-extrabold text-[#111827]">Journey Timeline</h2>
          <p className="mt-1 text-sm text-[#6b7280]">Next milestones</p>
          <div className="mt-6">
            <TimelineChart />
          </div>
        </div>
      </section>

      <section className="grid gap-6 xl:grid-cols-[1fr_1fr]">
        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <h2 className="text-xl font-extrabold text-[#111827]">Interest Radar</h2>
          <p className="mt-1 text-sm text-[#6b7280]">
            This will compare all six domains after assessments.
          </p>
          <div className="mt-4">
            <EmptyRadarChart />
          </div>
        </div>

        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <h2 className="text-xl font-extrabold text-[#111827]">
            Confidence & Communication
          </h2>
          <p className="mt-1 text-sm text-[#6b7280]">
            Separate from interest domain scoring.
          </p>

          <div className="mt-6 rounded-2xl bg-[#f6f7f4] p-5">
            <p className="text-sm font-semibold text-[#6b7280]">Communication Style</p>
            <p className="mt-2 text-2xl font-extrabold text-[#111827]">Pending</p>
            <p className="mt-2 text-sm leading-6 text-[#5f6673]">
              Complete Talk with Buddy to generate this snapshot.
            </p>
          </div>

          <div className="mt-6">
            <ConfidenceChart />
          </div>
        </div>
      </section>

      <section className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
        <h2 className="text-xl font-extrabold text-[#111827]">Recent Sessions</h2>
        <div className="mt-5 rounded-2xl border border-dashed border-[#d8ddd1] bg-[#fbfcf8] p-6 text-center">
          <p className="font-bold text-[#111827]">No sessions yet</p>
          <p className="mt-2 text-sm leading-6 text-[#6b7280]">
            Completed games and assessments will appear here.
          </p>
        </div>
      </section>
    </div>
  );
}

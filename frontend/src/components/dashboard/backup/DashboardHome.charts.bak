import { useAuth } from "../../hooks/useAuth";

const domains = [
  "Logical-Analytical",
  "Creative-Artistic",
  "Verbal-Linguistic",
  "Spatial-Visual",
  "Interpersonal-Social",
  "Bodily-Kinesthetic",
];

function StatCard({ label, value, helper }) {
  return (
    <div className="rounded-2xl border border-[#e4e7df] bg-white p-5 shadow-sm">
      <p className="text-sm font-semibold text-[#6b7280]">{label}</p>
      <p className="mt-3 text-3xl font-extrabold text-[#111827]">{value}</p>
      <p className="mt-2 text-sm text-[#6b7280]">{helper}</p>
    </div>
  );
}

export default function DashboardHome() {
  const { user } = useAuth();
  const childName = user?.name || "Your child";

  const completedGames = 0;
  const gemsEarned = 0;
  const hasAssessmentData = completedGames > 0;

  return (
    <div className="mx-auto max-w-7xl space-y-6">
      <section className="grid gap-5 xl:grid-cols-[1.5fr_0.9fr]">
        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <div className="flex flex-col justify-between gap-5 md:flex-row md:items-start">
            <div>
              <p className="text-sm font-bold uppercase tracking-[0.14em] text-[#1f7a4d]">
                Child Profile
              </p>

              <h1
                className="mt-2 text-4xl font-extrabold text-[#111827]"
                style={{ fontFamily: "'Baloo 2', cursive" }}
              >
                {childName}'s Interest Snapshot
              </h1>

              <p className="mt-3 max-w-2xl text-base leading-7 text-[#5f6673]">
                This dashboard will show current interests, engagement patterns,
                game progress, and communication insights after assessments are completed.
              </p>
            </div>

            <div className="rounded-2xl bg-[#f6f7f4] px-5 py-4">
              <p className="text-sm font-semibold text-[#6b7280]">Assessment status</p>
              <p className="mt-1 text-xl font-extrabold text-[#111827]">Not started</p>
              <p className="mt-1 text-sm text-[#6b7280]">No game data yet</p>
            </div>
          </div>
        </div>

        <div className="rounded-3xl border border-[#dce8d3] bg-[#eef7e8] p-6 shadow-sm">
          <p className="text-sm font-bold uppercase tracking-[0.14em] text-[#1f7a4d]">
            Parent Insight
          </p>

          <p className="mt-4 text-lg font-semibold leading-7 text-[#223226]">
            No AI insight is available yet. Once {childName} completes activities,
            this section will summarize current interests in parent-friendly language.
          </p>

          <p className="mt-4 text-sm leading-6 text-[#5f6673]">
            Insights are exploratory and are not career predictions.
          </p>
        </div>
      </section>

      <section className="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        <StatCard label="Games Completed" value={`${completedGames}/6`} helper="Adventure progress" />
        <StatCard label="Gems Earned" value={gemsEarned} helper="Earned after completed games" />
        <StatCard label="Top Interest" value="Pending" helper="Available after assessments" />
        <StatCard label="Confidence" value="Pending" helper="After Talk with Buddy" />
      </section>

      <section className="grid gap-6 xl:grid-cols-[1.4fr_0.9fr]">
        <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <div>
            <h2 className="text-xl font-extrabold text-[#111827]">Interest Domains</h2>
            <p className="mt-1 text-sm text-[#6b7280]">
              Scores will appear after each game is completed.
            </p>
          </div>

          <div className="mt-6 grid gap-4 md:grid-cols-2">
            {domains.map((domain) => (
              <div key={domain} className="rounded-2xl border border-[#edf0e8] bg-[#fbfcf8] p-4">
                <div className="flex items-start justify-between gap-3">
                  <div>
                    <h3 className="font-extrabold text-[#111827]">{domain}</h3>
                    <p className="mt-1 text-sm text-[#6b7280]">Not assessed yet</p>
                  </div>

                  <span className="rounded-full bg-white px-3 py-1 text-sm font-extrabold text-[#6b7280]">
                    --
                  </span>
                </div>

                <div className="mt-4 h-2 rounded-full bg-[#e5e9df]">
                  <div className="h-2 w-0 rounded-full bg-[#1f7a4d]" />
                </div>

                <p className="mt-3 text-sm leading-6 text-[#5f6673]">
                  Complete the related activity to generate this score.
                </p>
              </div>
            ))}
          </div>
        </div>

        <div className="space-y-6">
          <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
            <h2 className="text-xl font-extrabold text-[#111827]">
              Confidence & Communication
            </h2>

            <p className="mt-2 text-sm leading-6 text-[#6b7280]">
              This section stays separate from interest domain scores.
            </p>

            <div className="mt-6 rounded-2xl bg-[#f6f7f4] p-5">
              <p className="text-sm font-semibold text-[#6b7280]">Communication Style</p>
              <p className="mt-2 text-2xl font-extrabold text-[#111827]">Pending</p>
              <p className="mt-2 text-sm leading-6 text-[#5f6673]">
                Complete Talk with Buddy to generate a confidence snapshot.
              </p>
            </div>
          </div>

          <div className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
            <h2 className="text-xl font-extrabold text-[#111827]">Recent Sessions</h2>

            <div className="mt-5 rounded-2xl border border-dashed border-[#d8ddd1] bg-[#fbfcf8] p-6 text-center">
              <p className="font-bold text-[#111827]">No sessions yet</p>
              <p className="mt-2 text-sm leading-6 text-[#6b7280]">
                Completed games and assessments will appear here.
              </p>
            </div>
          </div>
        </div>
      </section>

      {!hasAssessmentData && (
        <section className="rounded-3xl border border-[#e4e7df] bg-white p-6 shadow-sm">
          <h2 className="text-xl font-extrabold text-[#111827]">Next Step</h2>
          <p className="mt-2 max-w-3xl text-sm leading-6 text-[#6b7280]">
            Start the Adventure Hub and complete the first activity to begin building
            {` ${childName}'s`} interest profile.
          </p>
        </section>
      )}
    </div>
  );
}
